# =====================================================================
# PRISMA — variáveis de ambiente
#
# Copie para a Vercel em: Settings > Environment Variables.
# NENHUMA delas pode aparecer no config.js nem no index.html.
# =====================================================================

# --- Supabase --------------------------------------------------------
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=
# A service role ignora a RLS. Só no servidor. Vazou, troque na hora.
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude (monta o master prompt a partir do texto do cliente) ------
ANTHROPIC_API_KEY=

# --- Magnific (gera as imagens) --------------------------------------
MAGNIFIC_API_KEY=

# --- Mercado Pago ----------------------------------------------------
MP_ACCESS_TOKEN=
# Deixe 1 enquanto estiver testando; apague ou ponha 0 na produção.
MP_SANDBOX=1

# --- Site ------------------------------------------------------------
SITE_URL=https://usarprisma.com.br
